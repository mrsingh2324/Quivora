# Server
PORT=4000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/quivora

# CORS — comma-separated list of allowed origins, or * for all (fine in dev)
CLIENT_URL=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
PLAYER_URL=http://localhost:3001

# Internal services
AI_SERVICE_URL=http://localhost:4100/api/ai/analyze

# Auth — CHANGE JWT_SECRET before deploying to production
JWT_SECRET=replace-this-with-a-long-random-secret
ADMIN_ACCESS_CODE=QUIVORA-ADMIN-2026

# Base URL this API is reachable at (used for OAuth callback URLs)
API_BASE_URL=http://localhost:4000

# Google OAuth (optional — leave blank to disable Google sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional — leave blank to disable GitHub sign-in)
# Use GH_OAUTH_* to avoid conflicts with GitHub Actions' reserved GITHUB_* namespace
GH_OAUTH_CLIENT_ID=
GH_OAUTH_CLIENT_SECRET=

# Redis (optional — enables multi-process Socket.io adapter + session persistence)
# Leave blank to run in single-process in-memory mode (fine for development)
# REDIS_URL=redis://localhost:6379
